{
    "name": "topbar",
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-left": 10,
    "margin-right": 10,
    "margin-bottom": 3,
    "modules-left": [
        "clock",
        "custom/hyprpicker",
        "custom/ScrollMPRIS"
    ],

    "modules-center": [
        "hyprland/workspaces"
    ],
    
    "modules-right": [
        "network",
        "bluetooth",
        "wireplumber",
        "backlight",
        "tray",
        "custom/power"
    ],
   
    "custom/hyprpicker": {
        "format": "у∞і±",
        "on-click": "hyprpicker -n --radius=60"
    },

    "hyprland/workspaces": {
        "format": "",
        "persistent-workspaces": {
            "*": 10
        }
    },

    "network": {
        "interface": "wlan0",
        "format": "{ifname}",
        "format-wifi": "пЗЂ  {essid}",
        "format-ethernet": "у∞КЧ  {ipaddr}/{cidr}",
        "format-disconnected": "", //An empty format will hide the module.
        "max-length": 50,
        "on-click": "nmsurf --launcher wofi"
    },

    "bluetooth": {
        "format": "пКФ {status}",
        "format-connected": "пКФ {device_alias}",
        "on-click": "blueman-manager"
    },
    
    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-source-muted": "{icon}",
        "format-icons": {
            "default": ["ођ§", "пАІ", "пА®"]
        },
        "reverse-scrolling": true
    },
    
    "custom/ScrollMPRIS": {
        "return-type": "json",
        "exec": "~/.config/waybar/scripts/music.sh",
        "escape": true,
        "on-click": "playerctl play-pause"
    },
    
    "backlight": {
        "device": "intel_backlight",
        "format": "{icon} {percent}%",
        "format-icons": ["оОН", "оПУ", "оПС", "оПП", "оПО", "оПН", "оПК", "оПИ", "оОЫ"],
        "reverse-scrolling": true
    },

    "battery": {
        "bat": "BAT1",
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"],
        "max-length": 25
    },

    "power-profiles-daemon": {
        "format": "{icon} {profile}",
        "tooltip": true,
        "format-icons": {
            "default": "пГІ",
            "performance": "пГІ",
            "balanced": "пЙО",
            "power-saver": "пБђ"
        }
    },

    "clock": {
        "interval": 1,
        "format": "{:%H:%M:%S}",
        "markup": true
    },

    "custom/power": {
        "format" : "вПї",
        "on-click": "wlogout"
    },
    
    "tray": {
        "icon-size": 18,
        "spacing": 6,
        "show-passive-items": true
    }
}
